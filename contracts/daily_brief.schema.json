{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pa://contracts/daily-brief.schema.json",
  "title": "DailyBriefRun",
  "type": "object",
  "required": [
    "schema_version",
    "workflow",
    "date",
    "top_3",
    "carryovers",
    "due_items",
    "preaching",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "workflow": {
      "const": "morning_routine"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "top_3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "carryovers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task"],
        "properties": {
          "task": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "due_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "payment", "due_date", "due_in_days"],
        "properties": {
          "label": {
            "type": "string",
            "enum": ["due_today", "due_tomorrow", "due_in_days"]
          },
          "payment": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "due_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "due_in_days": {
            "type": "integer"
          },
          "source": {
            "type": "string"
          },
          "weekend_note": {
            "type": "string"
          },
          "sequence_note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "stale_reminders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reminder", "reason"],
        "properties": {
          "reminder": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "preaching": {
      "type": "object",
      "required": ["upcoming_sunday", "is_preaching"],
      "properties": {
        "upcoming_sunday": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "is_preaching": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["daily_log_top3_written"],
      "properties": {
        "daily_log_top3_written": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
