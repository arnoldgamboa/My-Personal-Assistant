{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pa://contracts/weekly-review.schema.json",
  "title": "WeeklyReviewRun",
  "type": "object",
  "required": [
    "schema_version",
    "workflow",
    "date",
    "week_window_start",
    "week_window_end",
    "wins",
    "misses",
    "next_week_priorities",
    "preaching_status"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "workflow": {
      "const": "weekly_review"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "week_window_start": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "week_window_end": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "wins": {
      "type": "array",
      "items": { "type": "string" }
    },
    "misses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_week_priorities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "preaching_status": {
      "type": "object",
      "required": ["upcoming_sunday", "is_preaching"],
      "properties": {
        "upcoming_sunday": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "is_preaching": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
